    {"name": "schedule_cron", "description": "Schedule a cron job (5-field: min hour dom month dow).", "input_schema": {"type": "object", "properties": {"cron": {"type": "string"}, "prompt": {"type": "string"}, "recurring": {"type": "boolean"}, "durable": {"type": "boolean"}}, "required": ["cron", "prompt"]}},
